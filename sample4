package net.jpmchase.payroll.processor.common.parallel;

import lombok.Builder;
import lombok.Getter;

import java.util.function.Supplier;

@Getter
@Builder
public class ParallelTask<T> {

    private final String name;
    private final Class<T> responseType;
    private final Supplier<T> supplier;

    public static <T> ParallelTask<T> of(
            final String name,
            final Class<T> responseType,
            final Supplier<T> supplier
    ) {
        return ParallelTask.<T>builder()
                .name(name)
                .responseType(responseType)
                .supplier(supplier)
                .build();
    }
}

package net.jpmchase.payroll.processor.common.parallel;

import net.jpmchase.payroll.processor.exception.ProcessorException;
import net.jpmchase.payroll.processor.exception.ProcessorExceptionType;

import java.util.Collections;
import java.util.Map;

public class ParallelTaskResult {

    private final Map<String, Object> results;

    public ParallelTaskResult(final Map<String, Object> results) {
        this.results = Collections.unmodifiableMap(results);
    }

    public <T> T get(final String taskName, final Class<T> responseType) {
        final Object value = results.get(taskName);

        if (value == null) {
            throw ProcessorException.of(
                    ProcessorExceptionType.INFRA_RETRYABLE,
                    "PARALLEL_TASK_RESULT_NOT_FOUND",
                    "Parallel task result not found for taskName=" + taskName
            );
        }

        if (!responseType.isInstance(value)) {
            throw ProcessorException.of(
                    ProcessorExceptionType.INFRA_RETRYABLE,
                    "PARALLEL_TASK_RESULT_TYPE_MISMATCH",
                    "Parallel task result type mismatch for taskName=" + taskName
            );
        }

        return responseType.cast(value);
    }

    public Map<String, Object> asMap() {
        return results;
    }
}

package net.jpmchase.payroll.processor.common.parallel;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import net.jpmchase.payroll.processor.exception.ProcessorException;
import net.jpmchase.payroll.processor.exception.ProcessorExceptionType;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.stereotype.Component;

import java.time.Duration;
import java.util.Collection;
import java.util.LinkedHashMap;
import java.util.Map;
import java.util.concurrent.CompletableFuture;
import java.util.concurrent.CompletionException;
import java.util.concurrent.Executor;
import java.util.concurrent.TimeUnit;
import java.util.stream.Collectors;

@Slf4j
@Component
@RequiredArgsConstructor
public class ParallelTaskExecutor {

    @Qualifier("payrollParallelExecutor")
    private final Executor payrollParallelExecutor;

    private static final Duration DEFAULT_TIMEOUT = Duration.ofSeconds(20);

    public ParallelTaskResult execute(final Collection<ParallelTask<?>> tasks) {
        return execute(tasks, DEFAULT_TIMEOUT);
    }

    public ParallelTaskResult execute(
            final Collection<ParallelTask<?>> tasks,
            final Duration timeout
    ) {
        validateTasks(tasks);

        final Map<String, CompletableFuture<Object>> futures = tasks.stream()
                .collect(Collectors.toMap(
                        ParallelTask::getName,
                        task -> CompletableFuture.supplyAsync(
                                () -> executeTask(task),
                                payrollParallelExecutor
                        ),
                        (existing, duplicate) -> {
                            throw ProcessorException.of(
                                    ProcessorExceptionType.INFRA_RETRYABLE,
                                    "DUPLICATE_PARALLEL_TASK_NAME",
                                    "Duplicate parallel task name found"
                            );
                        },
                        LinkedHashMap::new
                ));

        try {
            CompletableFuture
                    .allOf(futures.values().toArray(new CompletableFuture[0]))
                    .orTimeout(timeout.toMillis(), TimeUnit.MILLISECONDS)
                    .join();

            final Map<String, Object> results = new LinkedHashMap<>();

            for (Map.Entry<String, CompletableFuture<Object>> entry : futures.entrySet()) {
                results.put(entry.getKey(), entry.getValue().join());
            }

            return new ParallelTaskResult(results);

        } catch (CompletionException ex) {
            throw unwrap(ex);
        } catch (Exception ex) {
            throw ProcessorException.of(
                    ProcessorExceptionType.INFRA_RETRYABLE,
                    "PARALLEL_EXECUTION_FAILED",
                    "Parallel execution failed",
                    ex
            );
        }
    }

    private Object executeTask(final ParallelTask<?> task) {
        try {
            log.info("[PARALLEL] Starting task={}", task.getName());

            final Object result = task.getSupplier().get();

            if (result == null) {
                throw ProcessorException.of(
                        ProcessorExceptionType.INFRA_RETRYABLE,
                        "PARALLEL_TASK_RETURNED_NULL",
                        "Parallel task returned null for taskName=" + task.getName()
                );
            }

            if (!task.getResponseType().isInstance(result)) {
                throw ProcessorException.of(
                        ProcessorExceptionType.INFRA_RETRYABLE,
                        "PARALLEL_TASK_RESPONSE_TYPE_MISMATCH",
                        "Parallel task returned invalid type for taskName=" + task.getName()
                );
            }

            log.info("[PARALLEL] Completed task={}", task.getName());

            return result;

        } catch (Exception ex) {
            log.error("[PARALLEL] Failed task={}", task.getName(), ex);
            throw new CompletionException(ex);
        }
    }

    private void validateTasks(final Collection<ParallelTask<?>> tasks) {
        if (tasks == null || tasks.isEmpty()) {
            throw ProcessorException.of(
                    ProcessorExceptionType.INFRA_RETRYABLE,
                    "NO_PARALLEL_TASKS_PROVIDED",
                    "No parallel tasks were provided"
            );
        }

        for (ParallelTask<?> task : tasks) {
            if (task == null) {
                throw ProcessorException.of(
                        ProcessorExceptionType.INFRA_RETRYABLE,
                        "NULL_PARALLEL_TASK",
                        "Null parallel task was provided"
                );
            }

            if (task.getName() == null || task.getName().isBlank()) {
                throw ProcessorException.of(
                        ProcessorExceptionType.INFRA_RETRYABLE,
                        "INVALID_PARALLEL_TASK_NAME",
                        "Parallel task name is missing"
                );
            }

            if (task.getResponseType() == null) {
                throw ProcessorException.of(
                        ProcessorExceptionType.INFRA_RETRYABLE,
                        "INVALID_PARALLEL_TASK_RESPONSE_TYPE",
                        "Parallel task response type is missing for taskName=" + task.getName()
                );
            }

            if (task.getSupplier() == null) {
                throw ProcessorException.of(
                        ProcessorExceptionType.INFRA_RETRYABLE,
                        "INVALID_PARALLEL_TASK_SUPPLIER",
                        "Parallel task supplier is missing for taskName=" + task.getName()
                );
            }
        }
    }

    private RuntimeException unwrap(final CompletionException ex) {
        Throwable cause = ex.getCause();

        while (cause instanceof CompletionException && cause.getCause() != null) {
            cause = cause.getCause();
        }

        if (cause instanceof ProcessorException processorException) {
            return processorException;
        }

        if (cause instanceof RuntimeException runtimeException) {
            return runtimeException;
        }

        return ProcessorException.of(
                ProcessorExceptionType.INFRA_RETRYABLE,
                "PARALLEL_EXECUTION_FAILED",
                "Parallel execution failed",
                cause
        );
    }
}

