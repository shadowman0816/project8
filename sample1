    /**
     * Persist only dirty changes.
     */
    private void persistSelective(
        PayrollEntity payrollEntity,
        RecalcContext ctx,
        Set<PayrollTransactionEntity> dirtyPayrollTxns,
        Set<EmployeeTransactionEntity> dirtyEmpTxns
    ) {
        // Persist payroll entity only if receiver failures exist OR you explicitly changed payrollEntity
        if (ctx.receiverErrorExists) {
            payrollPersistenceService.saveWithAudit(payrollEntity);
        }

        if (!dirtyPayrollTxns.isEmpty()) {
            payrollTransactionPersistenceService.saveAllWithAudit(new ArrayList<>(dirtyPayrollTxns));
        }

        if (!dirtyEmpTxns.isEmpty()) {
            employeeTransactionPersistenceService.saveAllWithAudit(new ArrayList<>(dirtyEmpTxns));
        }
    }

    /**
     * Cancellation logic (kept very close to your screenshot).
     */
    @Transactional
    public void initiatePayrollCancellation(
        final String payrollId,
        final PayrollHierarchy payrollHierarchy,
        final PIMErrorInterpreterUtil.PIMError pimErrorResponse
    ) {
        PayrollHierarchy tuple = Optional.ofNullable(payrollHierarchy)
            .orElseGet(() -> getPayrollHierarchy(payrollId));

        PayrollEntity payrollEntity = tuple.payrollEntity();
        List<PayrollTransactionEntity> payrollTransactionEntities = tuple.payrollTransactionEntities();
        List<EmployeeTransactionEntity> employeeTransactionEntities = tuple.employeeTransactionEntities();

        log.info("Cancelling payroll with srcPyrlId={}, processDate={}, historyIndicator={}",
            safe(() -> payrollEntity.getId().getSrcPyrlId()),
            safe(() -> payrollEntity.getId().getProcDt()),
            safe(() -> payrollEntity.getId().getHistIn())
        );

        PIMErrorInterpreterUtil.PIMError pimError = Optional.ofNullable(pimErrorResponse)
            .orElseGet(() -> new PIMErrorInterpreterUtil.PIMError(StringUtils.EMPTY, StringUtils.EMPTY));

        payrollEntity.setPyrlStsCd(PayrollStatus.CANCELLATION_INITIATED.getCode());

        if (StringUtils.isNotBlank(pimError.code())) {
            payrollEntity.setErrCd(pimError.code());
        }
        if (StringUtils.isNotBlank(pimError.message())) {
            payrollEntity.setErrDescTx(pimError.message());
        }

        payrollEntity.setSrcPyrlStsNm(UNPROCESSED);

        // Partner vs system initiated cancellation
        if (StringUtils.isBlank(pimError.code()) && StringUtils.isBlank(pimError.message())
            && StringUtils.isNotBlank(payrollEntity.getStsRsnTx())) {
            payrollEntity.setStsRsnTx(PARTNER_INITIATED_CANCELLATION);
        } else {
            payrollEntity.setStsRsnTx(SYSTEM_INITIATED_CANCELLATION);
        }

        payrollTransactionEntities.forEach(pt -> {
            pt.setTxnStsCd(TransactionStatus.CANCEL_INITIATED.getCode());
            if (StringUtils.isNotBlank(pimError.code())) {
                pt.setErrCd(pimError.code());
            }
            if (StringUtils.isNotBlank(pimError.message())) {
                pt.setErrDescTx(pimError.message());
            }
        });

        employeeTransactionEntities.forEach(et -> {
            et.setEmpTxnStsCd(TransactionStatus.CANCEL_INITIATED.getCode());
            if (StringUtils.isNotBlank(pimError.code())) {
                et.setErrCd(pimError.code());
            }
            if (StringUtils.isNotBlank(pimError.message())) {
                et.setErrDescTx(pimError.message());
            }
        });

        payrollPersistenceService.saveWithAudit(payrollEntity);
        payrollTransactionPersistenceService.saveAllWithAudit(payrollTransactionEntities);
        employeeTransactionPersistenceService.saveAllWithAudit(employeeTransactionEntities);
    }

