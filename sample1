    public PayrollHierarchy getPayrollHierarchy(final String payrollId) {
        log.info("Retrieving payroll hierarchy for srcPyrlId={}", payrollId);

        PayrollEntity payrollEntity = payrollRepository.findBySrcPayrollId(payrollId)
            .orElseThrow(() -> ProcessorException.of(
                ProcessorExceptionType.BUSINESS_VALIDATION,
                PayrollErrors.PAYROLL_RECORD_NOT_FOUND.getCode(),
                PayrollErrors.PAYROLL_RECORD_NOT_FOUND.formatMessage(payrollId)
            ));

        List<PayrollTransactionEntity> payrollTxns = payrollTransactionService.findAllBySourcePayrollId(payrollId);
        List<EmployeeTransactionEntity> empTxns = employeeTransactionService.findAllBySourcePayrollId(payrollId);

        return new PayrollHierarchy(payrollEntity, payrollTxns, empTxns);
    }

    /**
     * For top-level cancel: if hierarchy load fails due to infra, throw SYSTEM_RETRYABLE so SAF can retry.
     */
    private PayrollHierarchy getPayrollHierarchyOrThrowRetryable(final String payrollId) {
        try {
            return getPayrollHierarchy(payrollId);
        } catch (ProcessorException pe) {
            // If it's already a SYSTEM_RETRYABLE, bubble it
            if (pe.getType() == ProcessorExceptionType.SYSTEM_RETRYABLE) {
                throw pe;
            }
            // BUSINESS_VALIDATION -> this payroll truly doesn't exist: nothing to cancel, but you can decide policy.
            // Here we rethrow as-is.
            throw pe;
        } catch (Exception ex) {
            throw ProcessorException.of(
                ProcessorExceptionType.SYSTEM_RETRYABLE,
                PIMErrors.PIM_SERVICE_FAILED.getCode(),
                "Unable to load payroll hierarchy for cancellation. " + PIMErrors.PIM_SERVICE_FAILED.formatMessage(payrollId)
            );
        }
    }

    private Map<String, PayrollTransactionEntity> buildPayrollTxnMap(List<PayrollTransactionEntity> payrollTxns) {
        if (CollectionUtils.isEmpty(payrollTxns)) return new HashMap<>();
        return payrollTxns.stream()
            .filter(t -> StringUtils.isNotBlank(t.getSrcPymtInstrDtlId()))
            .collect(Collectors.toMap(PayrollTransactionEntity::getSrcPymtInstrDtlId, Function.identity(), (a, b) -> a));
    }

    private Map<String, EmployeeTransactionEntity> buildEmployeeTxnMap(List<EmployeeTransactionEntity> empTxns) {
        if (CollectionUtils.isEmpty(empTxns)) return new HashMap<>();
        return empTxns.stream()
            .filter(t -> StringUtils.isNotBlank(t.getSrcPymtInstrDtlId()))
            .collect(Collectors.toMap(EmployeeTransactionEntity::getSrcPymtInstrDtlId, Function.identity(), (a, b) -> a));
    }

    // ---------------------------
    // Selective update helpers
    // ---------------------------

    private boolean isReceiverFailure(PIMErrorInterpreterUtil.PIMError receiverError) {
        return receiverError != null && StringUtils.isNotBlank(receiverError.code());
    }

    private void markEmployeeFailure(EmployeeTransactionEntity empTxn, PIMErrorInterpreterUtil.PIMError err) {
        empTxn.setEmpTxnStsCd(TransactionStatus.FUNDING_FAILED.getCode());
        // keep your existing behavior (you had CHECK in screenshot)
        empTxn.setTxnModeCd(PaymentType.CHECK.getCode());
        empTxn.setErrCd(err.code());
        empTxn.setErrDescTx(err.message());
    }

    private void markPayrollTxnFailureIfNeeded(PayrollTransactionEntity payrollTxn, PIMErrorInterpreterUtil.PIMError err) {
        // Only set error fields (do not overwrite terminal statuses blindly)
        if (StringUtils.isNotBlank(err.code())) {
            payrollTxn.setErrCd(err.code());
        }
        if (StringUtils.isNotBlank(err.message())) {
            payrollTxn.setErrDescTx(err.message());
        }
    }

    // ---------------------------
    // Utility
    // ---------------------------

    private static BigDecimal nvl(BigDecimal v) {
        return v == null ? BigDecimal.ZERO : v;
    }

    private static <T> T safe(SupplierWithException<T> supplier) {
        try {
            return supplier.get();
        } catch (Exception e) {
            return null;
        }
    }

    @FunctionalInterface
    private interface SupplierWithException<T> {
        T get() throws Exception;
    }

    private static final class RecalcContext {
        private final String payrollId;
        private final PayrollEntity payrollEntity;

        private boolean receiverErrorExists = false;
        private BigDecimal totalFailedDisbursement = BigDecimal.ZERO;

        private RecalcContext(String payrollId, PayrollEntity payrollEntity) {
            this.payrollId = payrollId;
            this.payrollEntity = payrollEntity;
        }
    }

