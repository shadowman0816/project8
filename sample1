    private static final String SYSTEM_INITIATED_CANCELLATION = "System Initiated Cancellation";
    private static final String PARTNER_INITIATED_CANCELLATION = "Partner Initiated Cancellation";
    private static final String UNPROCESSED = "Unprocessed";

    /**
     * Single instruction response handler.
     *
     * Behavior:
     *  - If group/top-level error exists => cancel payroll
     *  - Else run receiver-level recalculation
     *  - If recalculation throws => cancel payroll (best-effort)
     *  - If hierarchy can't be loaded for cancel => throw SYSTEM_RETRYABLE (SAF retry)
     */
    @Transactional
    public void handlePIMResponse(final String payrollId, final InstructionResponse instructionResponse) {

        // If PIM response indicates group/top-level failure, cancel immediately.
        Optional.ofNullable(PIMErrorInterpreterUtil.getErrorForGroupFailure(instructionResponse))
            .ifPresentOrElse(
                pimError -> {
                    log.info("Payroll failed at top level/sender level. Cancelling payroll. payrollId={}, code={}",
                        payrollId, pimError.code());
                    PayrollHierarchy hierarchy = getPayrollHierarchyOrThrowRetryable(payrollId);
                    initiatePayrollCancellation(payrollId, hierarchy, pimError);
                },
                () -> {
                    // Otherwise process receiver-level updates (selective updates)
                    try {
                        List<InstructionResponse> singleton = Collections.singletonList(instructionResponse);
                        recalculatePayrollInternal(payrollId, singleton);
                    } catch (Exception ex) {
                        log.error("Top-level PIM post-processing failed. Cancelling payroll. payrollId={}", payrollId, ex);
                        PayrollHierarchy hierarchy = getPayrollHierarchyOrThrowRetryable(payrollId);
                        initiatePayrollCancellation(payrollId, hierarchy, null);
                    }
                }
            );
    }

    /**
     * Multi instruction response handler.
     *
     * Behavior:
     *  - If response is null/empty => cancel payroll (since we "received response but can't process")
     *  - Run receiver-level recalculation
     *  - If recalculation throws => cancel payroll (best-effort)
     *  - If hierarchy can't be loaded for cancel => throw SYSTEM_RETRYABLE (SAF retry)
     */
    @Transactional
    public void handlePIMResponse(final String payrollId, final MultiInstructionResponse multiInstructionResponse) {

        List<InstructionResponse> responses = Optional.ofNullable(multiInstructionResponse)
            .map(MultiInstructionResponse::getInstructionResponses)
            .orElse(Collections.emptyList());

        if (CollectionUtils.isEmpty(responses)) {
            log.error("PIM multi-instruction response is null/empty. Cancelling payroll. payrollId={}", payrollId);
            PayrollHierarchy hierarchy = getPayrollHierarchyOrThrowRetryable(payrollId);
            initiatePayrollCancellation(payrollId, hierarchy, null);
            return;
        }

        try {
            recalculatePayrollInternal(payrollId, responses);
        } catch (Exception ex) {
            log.error("Top-level PIM post-processing failed. Cancelling payroll. payrollId={}", payrollId, ex);
            PayrollHierarchy hierarchy = getPayrollHierarchyOrThrowRetryable(payrollId);
            initiatePayrollCancellation(payrollId, hierarchy, null);
        }
    }

    /**
     * Internal recalculation logic:
     *  - Loads hierarchy
     *  - Builds lookup maps
     *  - Iterates instruction responses
     *  - Updates ONLY failed receiver instructions (return code != 0 / receiver error present)
     *  - Persists ONLY dirty entities
     */
    private void recalculatePayrollInternal(final String payrollId, final List<InstructionResponse> instructionResponses) {

        PayrollHierarchy hierarchy = getPayrollHierarchy(payrollId);

        PayrollEntity payrollEntity = hierarchy.payrollEntity();

        Map<String, PayrollTransactionEntity> payrollTxnByInstrId =
            buildPayrollTxnMap(hierarchy.payrollTransactionEntities());

        Map<String, EmployeeTransactionEntity> empTxnByInstrId =
            buildEmployeeTxnMap(hierarchy.employeeTransactionEntities());

        RecalcContext ctx = new RecalcContext(payrollId, payrollEntity);

        // Dirty lists (persist only what changed)
        Set<EmployeeTransactionEntity> dirtyEmpTxns = new LinkedHashSet<>();
        Set<PayrollTransactionEntity> dirtyPayrollTxns = new LinkedHashSet<>();

        for (InstructionResponse ir : instructionResponses) {
            processSingleInstructionSelective(ir, payrollTxnByInstrId, empTxnByInstrId, ctx, dirtyPayrollTxns, dirtyEmpTxns);
        }

        // Apply payroll-level adjustments ONLY if receiver failures exist
        if (ctx.receiverErrorExists && ctx.totalFailedDisbursement.compareTo(BigDecimal.ZERO) > 0) {
            applyFailedDisbursementAdjustments(payrollEntity, ctx);
        }

        // Persist ONLY dirty entities
        persistSelective(payrollEntity, ctx, dirtyPayrollTxns, dirtyEmpTxns);
    }

    /**
     * Process a single instruction:
     *  - Determine receiver error / non-zero return code
     *  - If success => DO NOTHING (don’t touch DB)
     *  - If failure => update only that employee txn + related payroll txn (if applicable)
     *  - Sender response updates are also selective (only when sender has error/status change)
     */
    private void processSingleInstructionSelective(
        InstructionResponse ir,
        Map<String, PayrollTransactionEntity> payrollTxnByInstrId,
        Map<String, EmployeeTransactionEntity> empTxnByInstrId,
        RecalcContext ctx,
        Set<PayrollTransactionEntity> dirtyPayrollTxns,
        Set<EmployeeTransactionEntity> dirtyEmpTxns
    ) {
        if (ir == null) return;

        final String txnIdentifier = safe(ir::getTransactionIdentifier);
        if (StringUtils.isBlank(txnIdentifier)) {
            log.warn("Skipping instructionResponse with blank txnIdentifier. payrollId={}", ctx.payrollId);
            return;
        }

        // Receiver "return code != 0" modeled as error code present
        PIMErrorInterpreterUtil.PIMError receiverError = PIMErrorInterpreterUtil.getError(
            ir.getPaymentRejectReasonCode(),
            ir.getPaymentRejectReasonText(),
            ir.getError()
        );

        boolean receiverFailed = isReceiverFailure(receiverError);
        if (!receiverFailed) {
            // ✅ Key requirement: do NOT update successes
            // But you may still want to handle sender response failures for debit txns if they come separately.
            processSenderResponseSelective(ir, payrollTxnByInstrId, dirtyPayrollTxns);
            return;
        }

        ctx.receiverErrorExists = true;

        // Update employee txn only for failed instruction
        EmployeeTransactionEntity empTxn = empTxnByInstrId.get(txnIdentifier);
        if (empTxn != null) {
            markEmployeeFailure(empTxn, receiverError);
            ctx.totalFailedDisbursement = ctx.totalFailedDisbursement.add(nvl(empTxn.getTxnAm()));
            dirtyEmpTxns.add(empTxn);
        } else {
            log.warn("No EmployeeTransactionEntity found for failed txnIdentifier={}, payrollId={}",
                txnIdentifier, ctx.payrollId);
        }

        // Update payroll txn only for failed instruction (if you map by srcPymtInstrDtlId)
        PayrollTransactionEntity payrollTxn = payrollTxnByInstrId.get(txnIdentifier);
        if (payrollTxn != null) {
            markPayrollTxnFailureIfNeeded(payrollTxn, receiverError);
            dirtyPayrollTxns.add(payrollTxn);
        }

        // Sender response updates (debit txns) are selective
        processSenderResponseSelective(ir, payrollTxnByInstrId, dirtyPayrollTxns);
    }

    /**
     * Selective sender response processing:
     *  - Only update debit txns when sender response carries error OR status needs update
     *  - Avoid touching everything
     */
    private void processSenderResponseSelective(
        InstructionResponse instructionResponse,
        Map<String, PayrollTransactionEntity> payrollTxnByInstrId,
        Set<PayrollTransactionEntity> dirtyPayrollTxns
    ) {
        List<SenderResponse> senderResponses = Optional.ofNullable(instructionResponse)
            .map(InstructionResponse::getSenderResponses)
            .orElse(Collections.emptyList());

        if (CollectionUtils.isEmpty(senderResponses)) return;

        for (SenderResponse sr : senderResponses) {
            if (sr == null) continue;

            String txnIdentifier = safe(sr::getTransactionIdentifier);
            if (StringUtils.isBlank(txnIdentifier)) continue;

            PayrollTransactionEntity txn = payrollTxnByInstrId.get(txnIdentifier);
            if (txn == null) continue;

            // Only for debit transactions (as in your screenshot: crDrCd == 'D')
            if (txn.getCrDrCd() == null || !TxnConstants.TXN_DEBIT_CRD_CD.equals(txn.getCrDrCd())) {
                continue;
            }

            PIMErrorInterpreterUtil.PIMError senderError = PIMErrorInterpreterUtil.getError(
                sr.getPaymentRejectReasonCode(),
                sr.getPaymentRejectReasonText(),
                sr.getError()
            );

            String statusNm = safe(sr::getSourcePaymentsStatusName);

            boolean hasSenderError = (senderError != null && StringUtils.isNotBlank(senderError.code()));
            boolean shouldUpdateStatus = StringUtils.isNotBlank(statusNm);

            if (!hasSenderError && !shouldUpdateStatus) {
                continue; // do not touch DB
            }

            if (hasSenderError) {
                log.warn("Sender transaction failed for payrollId={}, pyrltxnId={}, srcPymtInstrDtlId={}, errorCode={}, errorMsg={}",
                    instructionResponse.getTransactionIdentifier(),
                    safe(() -> txn.getId().getPyrltxnId()),
                    txn.getSrcPymtInstrDtlId(),
                    senderError.code(),
                    senderError.message()
                );
                txn.setErrCd(senderError.code());
                txn.setErrDescTx(senderError.message());
            }

            if (shouldUpdateStatus) {
                // protect terminal statuses (same pattern you have in your employee section)
                if (!TransactionStatus.TRANSACTION_TERMINAL_STATUSES.contains(txn.getTxnStsCd())
                    && !TransactionStatus.PENDING.getCode().equalsIgnoreCase(txn.getTxnStsCd())) {

                    txn.setTxnStsCd(TransactionStatus.fromSBPStatusCode(statusNm).getCode());
                }
            }

            dirtyPayrollTxns.add(txn);
        }
    }

