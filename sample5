@Service
@RequiredArgsConstructor
@Slf4j
public class PaymentService {

    private final PayrollRepository payrollRepository;
    private final ContractorPaymentGroupRepository contractorPaymentGroupRepository;
    private final PayrollTransactionRepository payrollTransactionRepository;
    private final EmployeeTransactionRepository employeeTransactionRepository;
    private final ContractorPaymentRepository contractorPaymentRepository;

    public Map<String, List<Payment>> getPaymentsByPyrlEnrlIdsAndDate(
            final Set<String> pyrlEnrlIds,
            final LocalDate startDate,
            final LocalDate endDate
    ) {
        if (pyrlEnrlIds == null || pyrlEnrlIds.isEmpty()) {
            return Map.of();
        }

        final Timestamp startTimestamp = Timestamp.valueOf(startDate.atStartOfDay());
        final Timestamp endTimestamp = Timestamp.valueOf(endDate.atTime(23, 59, 59));

        final Map<String, List<Payment>> response = new HashMap<>();

        final List<PayrollEntity> payrollEntities =
                payrollRepository.findByEnrollmentIdsAndDateRange(pyrlEnrlIds, startTimestamp, endTimestamp);

        final Map<String, List<String>> payrollPayeeMap = getPayeesForPayrolls(payrollEntities);

        payrollEntities.forEach(entity -> {
            final String pyrlEnrlId = entity.getPyrlEnrlId(); // adjust if inside entity.getId()
            final Payment payment = toPayrollPaymentDetails(entity, payrollPayeeMap);

            response.computeIfAbsent(pyrlEnrlId, key -> new ArrayList<>())
                    .add(payment);
        });

        final List<ContractorPaymentGroupEntity> contractorPaymentGroups =
                contractorPaymentGroupRepository.findByEnrollmentIdsAndDateRange(
                        pyrlEnrlIds,
                        startTimestamp,
                        endTimestamp
                );

        final Map<String, List<ContractorPaymentEntity>> contractorPaymentsByGroupId =
                getContractorPaymentsByGroupId(contractorPaymentGroups);

        contractorPaymentGroups.forEach(groupEntity -> {
            final String pyrlEnrlId = groupEntity.getPyrlEnrlId(); // adjust if inside entity/id
            final List<Payment> contractorPayments =
                    toContractorPaymentDetails(groupEntity, contractorPaymentsByGroupId);

            response.computeIfAbsent(pyrlEnrlId, key -> new ArrayList<>())
                    .addAll(contractorPayments);
        });

        return response;
    }

    public List<Payment> getPaymentsByPyrlEnrlIdAndDate(
            final String pyrlEnrlId,
            final LocalDate startDate,
            final LocalDate endDate
    ) {
        return getPaymentsByPyrlEnrlIdsAndDate(Set.of(pyrlEnrlId), startDate, endDate)
                .getOrDefault(pyrlEnrlId, List.of());
    }

    private Payment toPayrollPaymentDetails(
            final PayrollEntity entity,
            final Map<String, List<String>> payrollPayeeMap
    ) {
        final String srcPyrlId = entity.getId().getSrcPyrlId();

        final LocalDate dlvrDueDt = entity.getDlvrDueDt();
        final LocalDateTime dlvrDueDtTime = dlvrDueDt != null ? dlvrDueDt.atStartOfDay() : null;

        return Payment.builder()
                .paymentIdentifier(srcPyrlId)
                .paymentStatusCode(entity.getPyrlStsCd())
                .paymentProcessDate(Optional.ofNullable(entity.getId().getProcDt())
                        .map(LocalDate::toString)
                        .orElse(""))
                .lastPaymentPostedDate(Optional.ofNullable(dlvrDueDtTime)
                        .map(dt -> dt.format(TIMESTAMP_FORMATTER))
                        .orElse(""))
                .paymentTypeName(entity.getPyrlDlvrTypeCd())
                .fundingAccountNumber(entity.getFundAcctNb())
                .bankIdentifier(entity.getFirmBnkId())
                .payees(payrollPayeeMap.getOrDefault(srcPyrlId, List.of()))
                .build();
    }

    private List<Payment> toContractorPaymentDetails(
            final ContractorPaymentGroupEntity groupEntity,
            final Map<String, List<ContractorPaymentEntity>> contractorPaymentsByGroupId
    ) {
        final String groupId = groupEntity.getId().getCntrtPymtGpId();

        final List<ContractorPaymentEntity> contractorPayments =
                contractorPaymentsByGroupId.getOrDefault(groupId, List.of());

        return contractorPayments.stream()
                .map(contractorPayment -> Payment.builder()
                        .paymentIdentifier(contractorPayment.getId().getSrcCntrtPymtId())
                        .paymentStatusCode(contractorPayment.getCntrtPymtStsCd())
                        .paymentProcessDate(Optional.ofNullable(groupEntity.getId().getProcDt())
                                .map(LocalDate::toString)
                                .orElse(""))
                        .lastPaymentPostedDate(Optional.ofNullable(groupEntity.getDlvrDueDt())
                                .map(LocalDate::toString)
                                .orElse(""))
                        .paymentTypeName(groupEntity.getPymtDlvrTypeCd())
                        .fundingAccountNumber(groupEntity.getFundAcctNb())
                        .bankIdentifier(groupEntity.getFirmBnkId())
                        .payees(List.of(contractorPayment.getSrcPayeeId()))
                        .build())
                .collect(Collectors.toList());
    }

    private Map<String, List<ContractorPaymentEntity>> getContractorPaymentsByGroupId(
            final List<ContractorPaymentGroupEntity> contractorPaymentGroups
    ) {
        if (contractorPaymentGroups == null || contractorPaymentGroups.isEmpty()) {
            return Map.of();
        }

        final Set<String> groupIds = contractorPaymentGroups.stream()
                .map(entity -> entity.getId().getCntrtPymtGpId())
                .filter(Objects::nonNull)
                .collect(Collectors.toSet());

        if (groupIds.isEmpty()) {
            return Map.of();
        }

        final List<ContractorPaymentEntity> contractorPayments =
                contractorPaymentRepository.findByCntrtPymtGpIdIn(groupIds)
                        .orElse(List.of());

        return contractorPayments.stream()
                .collect(Collectors.groupingBy(entity -> entity.getId().getCntrtPymtGpId()));
    }

    private Map<String, List<String>> getPayeesForPayrolls(final List<PayrollEntity> payrollEntities) {
        if (payrollEntities == null || payrollEntities.isEmpty()) {
            return Map.of();
        }

        final Set<String> srcPyrlIds = payrollEntities.stream()
                .map(entity -> entity.getId().getSrcPyrlId())
                .filter(Objects::nonNull)
                .collect(Collectors.toSet());

        if (srcPyrlIds.isEmpty()) {
            return Map.of();
        }

        final List<PayrollTransactionEntity> payrollTransactions =
                payrollTransactionRepository.findBySourcePayrollIdIn(srcPyrlIds)
                        .orElse(List.of());

        if (payrollTransactions.isEmpty()) {
            return Map.of();
        }

        final Map<String, List<String>> payrollTxnIdsBySrcPayrollId = payrollTransactions.stream()
                .collect(Collectors.groupingBy(
                        PayrollTransactionEntity::getSrcPyrlId, // adjust if inside id
                        Collectors.mapping(entity -> entity.getId().getPyrlTxnId(), Collectors.toList())
                ));

        final Set<String> payrollTxnIds = payrollTransactions.stream()
                .map(entity -> entity.getId().getPyrlTxnId())
                .filter(Objects::nonNull)
                .collect(Collectors.toSet());

        final List<EmployeeTransactionEntity> employeeTransactions =
                employeeTransactionRepository.findByPayrollTransactionIdIn(payrollTxnIds)
                        .orElse(List.of());

        final Map<String, List<String>> payeeIdsByPayrollTxnId = employeeTransactions.stream()
                .collect(Collectors.groupingBy(
                        EmployeeTransactionEntity::getPyrlTxnId, // adjust if inside id
                        Collectors.mapping(EmployeeTransactionEntity::getSrcPayeeId, Collectors.toList())
                ));

        final Map<String, List<String>> payeesBySrcPayrollId = new HashMap<>();

        payrollTxnIdsBySrcPayrollId.forEach((srcPayrollId, txnIds) -> {
            final List<String> payeeIds = txnIds.stream()
                    .flatMap(txnId -> payeeIdsByPayrollTxnId.getOrDefault(txnId, List.of()).stream())
                    .filter(Objects::nonNull)
                    .distinct()
                    .collect(Collectors.toList());

            payeesBySrcPayrollId.put(srcPayrollId, payeeIds);
        });

        return payeesBySrcPayrollId;
    }
}


