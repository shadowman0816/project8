@Service
@RequiredArgsConstructor
@Slf4j
public class CompanyManagementService {

    private final EnrollmentRepository enrollmentRepository;

    public Map<CompanyLookupKey, Pair<String, Company>> getCompaniesByCompanyIdsAndEcis(
            final List<CompanyPartyIdentifier> companyPartyIdentifiers
    ) {
        if (companyPartyIdentifiers == null || companyPartyIdentifiers.isEmpty()) {
            return Map.of();
        }

        final Set<String> companyIds = companyPartyIdentifiers.stream()
                .map(CompanyPartyIdentifier::getCompanyIdentifier)
                .filter(Objects::nonNull)
                .filter(id -> !id.isBlank())
                .collect(Collectors.toSet());

        final Set<String> enterprisePartyIds = companyPartyIdentifiers.stream()
                .map(CompanyPartyIdentifier::getRelatedEnterprisePartyIdentifier)
                .filter(Objects::nonNull)
                .filter(id -> !id.isBlank())
                .collect(Collectors.toSet());

        if (companyIds.isEmpty() || enterprisePartyIds.isEmpty()) {
            return Map.of();
        }

        final List<EnrollmentEntity> enrollmentEntities =
                enrollmentRepository.findByCompanyIdsAndEnterprisePartyIds(companyIds, enterprisePartyIds);

        return enrollmentEntities.stream()
                .collect(Collectors.toMap(
                        entity -> CompanyLookupKey.of(
                                entity.getSrcCoId(),
                                entity.getRelEntpPrtyId()
                        ),
                        this::toCompanyDetails,
                        (existing, duplicate) -> existing
                ));
    }

    public Pair<String, Company> getCompanyByIdAndECI(
            final String companyId,
            final String enterprisePartyIdentifier
    ) {
        return enrollmentRepository
                .getEnrollmentEntitiesByCompanyIdAndEnterprisePartyIdentifier(companyId, enterprisePartyIdentifier)
                .map(this::toCompanyDetails)
                .orElseGet(() -> Pair.of(companyId, createNotFoundCompany(companyId)));
    }

    private Company createNotFoundCompany(final String companyId) {
        return Company.builder()
                .companyIdentifier(companyId)
                .enrollmentStatusName("NOT_FOUND")
                .build();
    }

    private Pair<String, Company> toCompanyDetails(final EnrollmentEntity entity) {
        return Pair.of(
                entity.getPyrlEnrlId(),
                Company.builder()
                        .relatedEnterprisePartyIdentifier(entity.getRelEntpPrtyId())
                        .companyIdentifier(entity.getSrcCoId())
                        .enrollmentStatusName(entity.getEnrlStsCd())
                        .approvalDate(entity.getApprvTs() != null ? entity.getApprvTs().toString() : null)
                        .enrollmentEndDate(entity.getSuspTs() != null ? entity.getSuspTs().toString() : null)
                        .fundingAccountNumber(entity.getAcctNb())
                        .bankIdentifier(entity.getFirmBnkId())
                        .build()
        );
    }
}


