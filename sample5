@RestController
@RequiredArgsConstructor
public class BillingController {

    private final CompanyManagementService companyService;
    private final PaymentService paymentService;
    private final PayeeService payeeService;

    public ResponseEntity<?> getBillingDetails(
            @RequestHeader("client-id") String clientId,
            @RequestHeader("trace-id") String traceId,
            @RequestHeader("channel-type") String channelType,
            @RequestHeader(value = "request-id", required = false) String requestId,
            @RequestHeader(value = "user-agent", required = false) String userAgent,
            @RequestHeader(value = "user-id", required = false) String userId,
            @RequestHeader(value = "session-id", required = false) String sessionId,
            @RequestHeader(value = "session-cache", required = false) String sessionCache,
            @RequestHeader(value = "pod-id", required = false) String podId,
            @RequestHeader("online-profile-identifier") Double onlineProfileIdentifier,
            @RequestHeader("correlation-identifier") String correlationIdentifier,
            @RequestBody CustomerBillingInformationRequest request
    ) {
        validateRequest(request);

        final LocalDate startDate = LocalDate.parse(request.getBillingPeriodStartDate());
        final LocalDate endDate = LocalDate.parse(request.getBillingPeriodEndDate());

        final List<CompanyPartyIdentifier> companyPartyIdentifiers =
                Optional.ofNullable(request.getCompanyPartyIdentifiers())
                        .orElse(List.of());

        validateCompanyPartyIdentifiers(companyPartyIdentifiers);

        final Map<CompanyLookupKey, Pair<String, Company>> companyMap =
                companyService.getCompaniesByCompanyIdsAndEcis(companyPartyIdentifiers);

        final Set<String> pyrlEnrlIds = companyMap.values()
                .stream()
                .map(Pair::getFirst)
                .filter(Objects::nonNull)
                .collect(Collectors.toSet());

        final Map<String, List<Payment>> paymentsByEnrollmentId =
                paymentService.getPaymentsByPyrlEnrlIdsAndDate(pyrlEnrlIds, startDate, endDate);

        final Map<String, List<Payee>> payeesByEnrollmentId =
                payeeService.getAllPayeesForCompanies(pyrlEnrlIds);

        final List<Company> companies = companyPartyIdentifiers.stream()
                .map(companyPartyIdentifier -> {
                    final String srcCompanyId = companyPartyIdentifier.getCompanyIdentifier();
                    final String relEntpPrtyId = companyPartyIdentifier.getRelatedEnterprisePartyIdentifier();

                    final CompanyLookupKey key = CompanyLookupKey.of(srcCompanyId, relEntpPrtyId);

                    final Pair<String, Company> companyPair = companyMap.getOrDefault(
                            key,
                            Pair.of(srcCompanyId, createNotFoundCompany(srcCompanyId))
                    );

                    final String pyrlEnrlId = companyPair.getFirst();
                    final Company company = companyPair.getSecond();

                    company.setPayments(paymentsByEnrollmentId.getOrDefault(pyrlEnrlId, List.of()));
                    company.setPayees(payeesByEnrollmentId.getOrDefault(pyrlEnrlId, List.of()));

                    return company;
                })
                .collect(Collectors.toList());

        final CustomerBillingInformationResponse response =
                new CustomerBillingInformationResponse();

        response.setCompanies(companies);

        return ResponseEntity.ok(response);
    }

    private void validateCompanyPartyIdentifiers(
            final List<CompanyPartyIdentifier> companyPartyIdentifiers
    ) {
        if (companyPartyIdentifiers.isEmpty()) {
            throw BusinessErrorCode.INVALID_COMPANY_ID.asBadRequestException();
        }

        companyPartyIdentifiers.forEach(companyPartyIdentifier -> {
            final String srcCompanyId = companyPartyIdentifier.getCompanyIdentifier();
            final String relEntpPrtyId =
                    companyPartyIdentifier.getRelatedEnterprisePartyIdentifier();

            if (srcCompanyId == null || srcCompanyId.isEmpty()) {
                throw BusinessErrorCode.INVALID_COMPANY_ID.asBadRequestException();
            }

            if (relEntpPrtyId == null || relEntpPrtyId.isEmpty()) {
                throw BusinessErrorCode.INVALID_ENTERPRISE_PARTY_ID.asBadRequestException();
            }
        });
    }

    private Company createNotFoundCompany(final String companyId) {
        return Company.builder()
                .companyIdentifier(companyId)
                .enrollmentStatusName("NOT_FOUND")
                .payments(List.of())
                .payees(List.of())
                .build();
    }

    private void validateRequest(final CustomerBillingInformationRequest request) {
        if (request == null) {
            throw BusinessErrorCode.INVALID_REQUEST.asBadRequestException();
        }

        if (request.getBillingPeriodStartDate() == null) {
            throw BusinessErrorCode.INVALID_START_DATE.asBadRequestException();
        }

        if (request.getBillingPeriodEndDate() == null) {
            throw BusinessErrorCode.INVALID_END_DATE.asBadRequestException();
        }

        final LocalDate startDate = LocalDate.parse(request.getBillingPeriodStartDate());
        final LocalDate endDate = LocalDate.parse(request.getBillingPeriodEndDate());

        if (endDate.isBefore(startDate)) {
            throw BusinessErrorCode.INVALID_DATE_RANGE.asBadRequestException();
        }
    }
}



@Service
@RequiredArgsConstructor
@Slf4j
public class PayeeService {

    private final PayeeRepository payeeRepository;

    public Map<String, List<Payee>> getAllPayeesForCompanies(final Set<String> pyrlEnrlIds) {
        if (pyrlEnrlIds == null || pyrlEnrlIds.isEmpty()) {
            return Map.of();
        }

        return payeeRepository.findAllPayeesByPyrlEnrlIdIn(pyrlEnrlIds)
                .stream()
                .map(this::toPayeeDetailsWithEnrollmentId)
                .collect(Collectors.groupingBy(
                        PayeeWithEnrollment::getPyrlEnrlId,
                        Collectors.mapping(PayeeWithEnrollment::getPayee, Collectors.toList())
                ));
    }

    public List<Payee> getAllPayeesForACompany(final String pyrlEnrlId) {
        return getAllPayeesForCompanies(Set.of(pyrlEnrlId))
                .getOrDefault(pyrlEnrlId, List.of());
    }

    private PayeeWithEnrollment toPayeeDetailsWithEnrollmentId(final PayeeEntity entity) {
        return PayeeWithEnrollment.builder()
                .pyrlEnrlId(entity.getPyrlEnrlId()) // adjust getter if needed
                .payee(toPayeeDetails(entity))
                .build();
    }

    private Payee toPayeeDetails(final PayeeEntity entity) {
        final LocalDate hireDt = entity.getHireDt();
        final LocalDateTime hireDtTime = hireDt != null ? hireDt.atStartOfDay() : null;

        final LocalDate trmnDt = entity.getTrmnDt();
        final LocalDateTime trmnDtTime = trmnDt != null ? trmnDt.atStartOfDay() : null;

        return Payee.builder()
                .payeeIdentifier(entity.getSrcPayeeId())
                .payeeStatusName(entity.getSrcPayeeStsNm())
                .payeeHireStartDate(Optional.ofNullable(hireDtTime)
                        .map(dt -> dt.format(TIMESTAMP_FORMATTER))
                        .orElse(""))
                .payeeTerminationDate(Optional.ofNullable(trmnDtTime)
                        .map(dt -> dt.format(TIMESTAMP_FORMATTER))
                        .orElse(""))
                .payeeTypeName(entity.getPayeeTypeCd())
                .build();
    }

    @Value
    @Builder
    private static class PayeeWithEnrollment {
        String pyrlEnrlId;
        Payee payee;
    }
}


